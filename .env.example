# ── OpenAI (AI Assistant + Daily Digest) ────────────────────────────────────
# Sign up: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# gpt-5-mini is the sweet spot for digest/chat: reliable tool-use, better
# editorial judgment than nano (picks real films vs biographical docs).
# Drop to gpt-5-nano only if cost becomes a concern.
OPENAI_MODEL=gpt-5-mini

# ── TMDB (movie / series posters) ───────────────────────────────────────────
# Optional. Without it posters fall back to Wikipedia (less coverage, lower quality).
# Sign up (free): https://www.themoviedb.org/signup
# Then grab the short v3 key labeled "API Key" (NOT the long "API Read Access Token"):
#   https://www.themoviedb.org/settings/api
# API endpoint used: https://api.themoviedb.org/3/search/multi
TMDB_API_KEY=

# ── Unsplash (sport tile photos) ────────────────────────────────────────────
# Optional. Used as final fallback for sport tiles when Wikipedia/TMDB have
# nothing — returns real team/stadium/equipment photos instead of generic art.
# Sign up (free): https://unsplash.com/developers → "New Application"
# Demo tier: 50 req/hour — enough for digest load. Copy the "Access Key".
UNSPLASH_ACCESS_KEY=

# ── Telegram bot (plan notifications) ───────────────────────────────────────
# When a user clicks "Запланировать" in Today / Assistant, the server posts a
# poster card to a Telegram chat — once when the plan is created and again
# when the show is about to start (with a deep-link back to the stream).
#
# 1. Create a bot via @BotFather and copy the HTTP API token here.
#    Upload /Users/andreystepanov/projects/m3uplaylist/bot_logo.png as the
#    bot's avatar (BotFather → /setuserpic).
# 2. Add the bot to your group/channel and make it admin (needed to post).
# 3. Chat id: easiest path — send a message in the chat, then GET
#    https://api.telegram.org/bot<TOKEN>/getUpdates and read chat.id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Base URL that Telegram clients will use to reach this server when tapping
# the "Watch now" button. For local dev: http://<LAN-ip>:8000. For prod: your
# public HTTPS domain. Leave empty to disable deep-link buttons in messages.
PUBLIC_BASE_URL=
