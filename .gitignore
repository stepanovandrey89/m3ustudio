# ── Playlist & media files ──────────────────────────────────────────────────
*.m3u
*.m3u8

# ── Caches & runtime data ────────────────────────────────────────────────────
# Anchor runtime dirs to repo root so they don't shadow the server/recordings/
# Python package that lives next to server/ai/, server/planner/, etc.
/logos_cache/
/epg_cache/
/transcode_tmp/
/ai_cache/
/recordings/
/state.json
/plans.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/
*.egg
.mypy_cache/
.ruff_cache/

# ── Node / frontend ──────────────────────────────────────────────────────────
web/node_modules/
web/dist/
web/.vite/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
/scripts/.deploy.env

# ── Editor & OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
